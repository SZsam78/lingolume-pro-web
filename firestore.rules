rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // AUTH REQUIRED: Allow any authenticated user to read courses, lessons, and modules
    match /modules/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /lessons/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /tasks/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // VOCABULARY: Accessible by all students
    match /vocabulary/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // USER DATA: Students only read/write their own record
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow progress tracking
      match /progress/{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Default: deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
